# ============================================
# RedLeg Hardwood Calculator — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Database (Supabase PostgreSQL) ──────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler string (port 6543) for serverless/Vercel.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.[ref]:[YOUR-DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# For Prisma migrations ONLY — use the "Direct" connection (port 5432, no pooler).
# This is NOT used at runtime. Only needed when running `prisma migrate deploy`.
DIRECT_URL="postgresql://postgres.[ref]:[YOUR-DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ── Supabase API (for client/server SDK usage) ──
# Get these from: Supabase Dashboard → Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_URL="https://[your-project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your-anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[your-service-role-key]"

# ── LLM API (for PDF price-sheet parsing) ───
# The PDF parser uses an OpenAI-compatible API to extract prices from uploaded PDFs.
# Option A — Abacus AI RouteLLM (current):
#   Sign up at https://abacus.ai and get an API key from Settings → API Keys
ABACUSAI_API_KEY=""
# Option B — OpenAI direct:
#   Change the fetch URL in app/api/upload/pdf/route.ts to https://api.openai.com/v1/chat/completions
#   and set OPENAI_API_KEY here instead. Model used: gpt-4.1

# ── App URL ─────────────────────────────────
# Set to your Vercel deployment URL (no trailing slash).
# Vercel auto-sets VERCEL_URL but NEXTAUTH_URL is used for metadata / OG images.
NEXTAUTH_URL="https://your-app.vercel.app"

# ── File Storage (Optional) ─────────────────
# Only needed if you want PDF file storage in S3.
# If omitted, the PDF parser still works — it just won't persist the uploaded file.
# AWS_REGION="us-west-2"
# AWS_BUCKET_NAME="your-bucket"
# AWS_FOLDER_PREFIX="redleg/"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
